<!DOCTYPE html>
<html>
<head>
    <title>Riwayat Deposit - <%= appName || 'DK PANEL' %></title>
    <%- include('partials/panel-head') %>
</head>
<body class="mp-body">
<div class="mp-layout">
    <%- include('partials/user-sidebar') %>
    <main class="mp-main deposits-page-v25">
        <%- include('partials/panel-top', {title:'Riwayat Deposit', subtitle:'Pantau request deposit, status approval, dan saldo yang sudah masuk.'}) %>
        <%
            const list = deposits || [];
            const saldoUser = Number((user && user.saldo) || 0);
            const isApproved = d => ['approved','sukses','success'].includes(String(d.status||'').toLowerCase());
            const isPending = d => String(d.status||'').toLowerCase()==='pending';
            const approvedTotal = list.filter(isApproved).reduce((a,d)=>a+Number(d.amount||0),0);
            const pendingTotal = list.filter(isPending).reduce((a,d)=>a+Number(d.amount||0),0);
        %>
        <% if(typeof pageError !== 'undefined' && pageError){ %><div class="mp-alert"><%= pageError %></div><% } %>
        <div class="mp-stat-grid deposit-balance-grid deposit-summary-v25">
            <div class="mp-stat deposit-balance-card"><span>💰</span><p>Saldo Aktif</p><strong>Rp <%= saldoUser.toLocaleString('id-ID') %></strong><small>Bisa dipakai untuk order.</small></div>
            <div class="mp-stat"><span>✓</span><p>Deposit Disetujui</p><strong>Rp <%= approvedTotal.toLocaleString('id-ID') %></strong><small>Total deposit yang sudah masuk saldo.</small></div>
            <div class="mp-stat"><span>⏳</span><p>Deposit Pending</p><strong>Rp <%= pendingTotal.toLocaleString('id-ID') %></strong><small>Belum masuk saldo aktif.</small></div>
        </div>

        <section class="mp-card">
            <div class="mp-card-head deposit-card-head-v25">
                <div><h2>▣ Riwayat Deposit</h2><p>Gunakan filter untuk cek deposit pending, sukses, atau ditolak.</p></div>
                <a href="/deposit" class="mp-btn small">Tambah Deposit</a>
            </div>
            <div class="deposit-history-toolbar-v25">
                <select id="depositStatusFilter"><option value="">Semua Status</option><option value="pending">Pending</option><option value="approved">Approved</option><option value="rejected">Rejected</option></select>
                <select id="depositMethodFilter"><option value="">Semua Metode</option></select>
                <div class="mp-search"><input id="depositSearch" placeholder="Cari ID/metode/catatan..."><button type="button">🔍</button></div>
            </div>
            <div class="mp-table-wrap">
                <table class="mp-table deposit-table-v25" id="depositTable">
                    <thead><tr><th>ID</th><th>Dibuat</th><th>Metode</th><th>Saldo Masuk</th><th>Total Bayar</th><th>Bukti</th><th>Status</th><th>Keterangan</th></tr></thead>
                    <tbody>
                    <% if(list.length===0){ %><tr><td colspan="8" class="empty-cell">Belum ada deposit.</td></tr><% } %>
                    <% list.forEach(d=>{ const st=String(d.status||'').toLowerCase(); %>
                        <tr class="deposit-row-v25" data-status="<%= st %>" data-method="<%= String(d.metode||'').toLowerCase() %>" data-search="<%= String((d.id||'')+' '+(d.metode||'')+' '+(d.admin_note||'')).toLowerCase() %>">
                            <td><span class="mp-id">#<%= d.id %></span></td>
                            <td><%= d.created_at ? new Date(d.created_at).toLocaleString('id-ID') : '-' %></td>
                            <td><strong><%= d.metode || '-' %></strong><br><small><%= d.payment_type || '-' %></small></td>
                            <td>Rp <%= Number(d.amount||0).toLocaleString('id-ID') %></td>
                            <td><strong>Rp <%= Number(d.total_pay || d.amount || 0).toLocaleString('id-ID') %></strong><br><small>Fee Rp <%= Number(d.fee_amount || 0).toLocaleString('id-ID') %> • Kode Rp <%= Number(d.unique_code || 0).toLocaleString('id-ID') %></small></td>
                            <td><% if(d.proof_image){ %><a href="<%= d.proof_image %>" target="_blank" class="mp-btn small mp-btn-soft">Lihat</a><% } else { %>-<% } %></td>
                            <td><%- include('partials/status',{status:d.status}) %></td>
                            <td><% if(isApproved(d)){ %><span class="balance-note ok">Sudah masuk saldo</span><% } else if(isPending(d)){ %><span class="balance-note wait">Menunggu admin</span><% } else { %><span class="balance-note muted-note"><%= d.admin_note || 'Tidak masuk saldo' %></span><% } %></td>
                        </tr>
                    <% }) %>
                    </tbody>
                </table>
            </div>
        </section>
    </main>
</div>
<script>
(function(){
    const rows = Array.from(document.querySelectorAll('.deposit-row-v25'));
    const status = document.getElementById('depositStatusFilter');
    const method = document.getElementById('depositMethodFilter');
    const search = document.getElementById('depositSearch');
    const methods = [...new Set(rows.map(row => row.dataset.method).filter(Boolean))].sort();
    methods.forEach(m => { const opt = document.createElement('option'); opt.value = m; opt.textContent = m.toUpperCase(); method?.appendChild(opt); });
    function apply(){
        const st = status?.value || '';
        const mt = method?.value || '';
        const q = (search?.value || '').toLowerCase();
        rows.forEach(row => {
            const ok = (!st || row.dataset.status === st) && (!mt || row.dataset.method === mt) && (!q || row.dataset.search.includes(q));
            row.style.display = ok ? '' : 'none';
        });
    }
    status?.addEventListener('change', apply); method?.addEventListener('change', apply); search?.addEventListener('input', apply);
})();
</script>
</body>
</html>
