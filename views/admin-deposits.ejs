<!DOCTYPE html><html><head><title>Admin Deposit - <%= appName || 'DK PANEL' %></title><%- include('partials/panel-head') %></head><body class="mp-body"><div class="mp-layout"><%- include('partials/admin-sidebar') %><main class="mp-main"><%- include('partials/panel-top', {title:'Admin Deposit', subtitle:'Approve atau reject request deposit.'}) %><section class="mp-card"><div class="mp-card-head"><h2>▣ Deposit</h2></div><div class="mp-table-wrap"><table class="mp-table"><thead><tr><th>ID</th><th>User</th><th>Metode</th><th>Jumlah</th><th>Bukti</th><th>Status</th><th>Aksi</th></tr></thead><tbody><% if((deposits||[]).length===0){ %><tr><td colspan="7" class="empty-cell">Belum ada deposit.</td></tr><% } %><% (deposits||[]).forEach(d=>{ %><tr><td><%= d.id %></td><td><b><%= d.username %></b><br><small><%= d.email %></small></td><td><%= d.metode %></td><td>Rp <%= Number(d.amount||0).toLocaleString('id-ID') %></td><td><% if(d.proof_image){ %><a class="mp-btn small" href="<%= d.proof_image %>" target="_blank">Lihat</a><% } else { %>-<% } %></td><td><%- include('partials/status',{status:d.status}) %></td><td><% if(d.status === 'Pending'){ %><form action="/admin/deposit/update" method="POST" class="inline-form"><input type="hidden" name="id" value="<%= d.id %>"><button name="status" value="Approved" class="mp-btn small green">Approve</button><button name="status" value="Rejected" class="mp-btn small danger">Reject</button></form><% } else { %><span class="muted">Selesai</span><% } %></td></tr><% }) %></tbody></table></div></section></main></div></body></html>
