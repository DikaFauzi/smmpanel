<!DOCTYPE html><html><head><title>Metode Pembayaran - <%= appName %></title><link rel="stylesheet" href="/style.css"></head><body class="mp-app-body"><div class="layout"><%- include('partials/admin-sidebar', { active: 'payment-methods' }) %><main class="content"><div class="topbar"><div><h1>Metode Pembayaran</h1><p>Kelola metode deposit manual yang tampil ke customer.</p></div></div><div class="form-card compact-form"><h2>Tambah Metode</h2><form action="/admin/payment-methods/add" method="POST" class="service-form-grid"><input type="hidden" name="_csrf" value="<%= csrfToken %>"><input name="name" placeholder="Nama metode" required><input name="type" placeholder="bank/ewallet/qris/manual"><input name="account_name" placeholder="Nama rekening"><input name="account_number" placeholder="Nomor rekening/tujuan"><input name="instructions" placeholder="Instruksi"><select name="is_active"><option value="1">Aktif</option><option value="0">Nonaktif</option></select><button>Tambah</button></form></div><div class="table-card"><table><thead><tr><th>ID</th><th>Nama</th><th>Tipe</th><th>Tujuan</th><th>Instruksi</th><th>Status</th><th>Aksi</th></tr></thead><tbody><% methods.forEach(method=>{ %><tr><td>#<%= method.id %></td><td><%= method.name %></td><td><%= method.type %></td><td><%= method.account_name || '-' %><br><span class="muted"><%= method.account_number || '-' %></span></td><td><%= method.instructions || '-' %></td><td><span class="status <%= method.is_active ? 'active' : 'inactive' %>"><%= method.is_active ? 'Aktif' : 'Nonaktif' %></span></td><td><form action="/admin/payment-methods/update" method="POST" class="inline-form"><input type="hidden" name="_csrf" value="<%= csrfToken %>"><input type="hidden" name="id" value="<%= method.id %>"><input name="name" value="<%= method.name %>"><input name="type" value="<%= method.type %>"><input name="account_name" value="<%= method.account_name || '' %>"><input name="account_number" value="<%= method.account_number || '' %>"><input name="instructions" value="<%= method.instructions || '' %>"><select name="is_active"><option value="1" <%= method.is_active ? 'selected':'' %>>Aktif</option><option value="0" <%= !method.is_active ? 'selected':'' %>>Nonaktif</option></select><button>Update</button></form></td></tr><% }) %></tbody></table></div></main></div></body></html>