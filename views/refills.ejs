<!DOCTYPE html><html><head><title>Refill - <%= appName %></title><link rel="stylesheet" href="/style.css"></head><body class="mp-app-body"><div class="layout"><%- include('partials/user-sidebar', { active: 'refills' }) %><main class="content"><div class="topbar"><div><h1>Request Refill</h1><p>Ajukan refill untuk order yang punya garansi refill.</p></div></div><div class="form-card compact-form"><h2>Ajukan Refill</h2><form action="/refills" method="POST" class="service-form-grid"><input type="hidden" name="_csrf" value="<%= csrfToken %>"><select name="order_id" required><option value="">Pilih order eligible</option><% eligibleOrders.forEach(order=>{ %><option value="<%= order.id %>">#<%= order.id %> - <%= order.service_name %></option><% }) %></select><input type="text" name="reason" placeholder="Alasan refill"><button type="submit">Kirim Request</button></form></div><div class="table-card"><table><thead><tr><th>ID</th><th>Order</th><th>Layanan</th><th>Target</th><th>Alasan</th><th>Status</th><th>Catatan Admin</th><th>Waktu</th></tr></thead><tbody><% refills.forEach(item=>{ %><tr><td>#<%= item.id %></td><td>#<%= item.order_id %></td><td><%= item.service_name %></td><td><%= item.target %></td><td><%= item.reason || '-' %></td><td><span class="status <%= item.status %>"><%= item.status %></span></td><td><%= item.admin_note || '-' %></td><td><%= item.created_at ? new Date(item.created_at).toLocaleString('id-ID') : '-' %></td></tr><% }) %></tbody></table></div></main></div></body></html>