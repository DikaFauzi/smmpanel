<!DOCTYPE html>
<html>
<head>
    <title>Notifikasi Admin - <%= appName %></title>
    <link rel="stylesheet" href="/style.css">
</head>
<body class="mp-app-body">
<div class="layout">
    <%- include('partials/admin-sidebar', { active: 'notifications' }) %>
    <main class="content">
        <div class="topbar">
            <div><h1>Notifikasi Admin</h1><p>Signal cepat untuk deposit, order, dan proses yang butuh respon.</p></div>
            <form action="/admin/notifications/read" method="POST">
                <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                <button type="submit">Tandai Sudah Dibaca</button>
            </form>
        </div>
        <div class="table-card notification-list">
            <% if(notifications.length === 0){ %><div class="empty">Belum ada notifikasi.</div><% } %>
            <% notifications.forEach(item => { %>
                <div class="notification-item <%= item.is_read ? '' : 'unread' %>">
                    <div>
                        <strong><%= item.title %></strong>
                        <p><%= item.message %></p>
                        <span class="muted"><%= item.created_at ? new Date(item.created_at).toLocaleString('id-ID') : '-' %></span>
                    </div>
                    <span class="status <%= item.type %>"><%= item.type %></span>
                </div>
            <% }) %>
        </div>
    </main>
</div>
</body>
</html>
