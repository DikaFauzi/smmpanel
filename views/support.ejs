<!DOCTYPE html><html><head><title>Support - <%= appName %></title><link rel="stylesheet" href="/style.css"></head><body class="mp-app-body"><div class="layout"><%- include('partials/user-sidebar', { active: 'support' }) %><main class="content"><div class="topbar"><div><h1>Support Ticket</h1><p>Kirim pertanyaan, komplain order, atau bantuan deposit.</p></div></div><div class="form-card compact-form"><h2>Buat Ticket</h2><form action="/support" method="POST" class="service-form-grid"><input type="hidden" name="_csrf" value="<%= csrfToken %>"><input type="text" name="subject" placeholder="Subject" required><select name="category"><option value="order">Order</option><option value="deposit">Deposit</option><option value="refill">Refill</option><option value="general">General</option></select><textarea name="message" placeholder="Tulis detail masalah" required></textarea><button type="submit">Kirim Ticket</button></form></div><div class="table-card"><table><thead><tr><th>ID</th><th>Subject</th><th>Kategori</th><th>Pesan</th><th>Status</th><th>Balasan Admin</th><th>Waktu</th></tr></thead><tbody><% tickets.forEach(ticket=>{ %><tr><td>#<%= ticket.id %></td><td><%= ticket.subject %></td><td><%= ticket.category %></td><td><%= ticket.message %></td><td><span class="status <%= ticket.status %>"><%= ticket.status %></span></td><td><%= ticket.admin_note || '-' %></td><td><%= ticket.created_at ? new Date(ticket.created_at).toLocaleString('id-ID') : '-' %></td></tr><% }) %></tbody></table></div></main></div></body></html>