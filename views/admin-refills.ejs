<!DOCTYPE html><html><head><title>Refill Admin - <%= appName %></title><link rel="stylesheet" href="/style.css"></head><body class="mp-app-body"><div class="layout"><%- include('partials/admin-sidebar', { active: 'refills' }) %><main class="content"><div class="topbar"><div><h1>Request Refill</h1><p>Kelola refill manual/auto dari user.</p></div></div><div class="table-card"><table><thead><tr><th>ID</th><th>User</th><th>Order</th><th>Layanan</th><th>Target</th><th>Alasan</th><th>Status</th><th>Aksi</th></tr></thead><tbody><% refills.forEach(item=>{ %><tr><td>#<%= item.id %></td><td><%= item.username %><br><span class="muted"><%= item.email %></span></td><td>#<%= item.order_id %></td><td><%= item.service_name %></td><td><%= item.target %></td><td><%= item.reason || '-' %></td><td><span class="status <%= item.status %>"><%= item.status %></span></td><td><form action="/admin/refills/update" method="POST" class="inline-form"><input type="hidden" name="_csrf" value="<%= csrfToken %>"><input type="hidden" name="id" value="<%= item.id %>"><select name="status"><% ['Pending','Processing','Completed','Rejected'].forEach(s=>{ %><option value="<%= s %>" <%= item.status===s?'selected':'' %>><%= s %></option><% }) %></select><input name="admin_note" placeholder="Catatan" value="<%= item.admin_note || '' %>"><button type="submit">Update</button></form></td></tr><% }) %></tbody></table></div></main></div></body></html>