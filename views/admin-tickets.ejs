<!DOCTYPE html><html><head><title>Ticket Admin - <%= appName %></title><link rel="stylesheet" href="/style.css"></head><body class="mp-app-body"><div class="layout"><%- include('partials/admin-sidebar', { active: 'tickets' }) %><main class="content"><div class="topbar"><div><h1>Support Ticket</h1><p>Respon ticket customer dari satu halaman.</p></div></div><div class="table-card"><table><thead><tr><th>ID</th><th>User</th><th>Subject</th><th>Kategori</th><th>Pesan</th><th>Status</th><th>Aksi</th></tr></thead><tbody><% tickets.forEach(ticket=>{ %><tr><td>#<%= ticket.id %></td><td><%= ticket.username %><br><span class="muted"><%= ticket.email %></span></td><td><%= ticket.subject %></td><td><%= ticket.category %></td><td><%= ticket.message %></td><td><span class="status <%= ticket.status %>"><%= ticket.status %></span></td><td><form action="/admin/tickets/update" method="POST" class="inline-form"><input type="hidden" name="_csrf" value="<%= csrfToken %>"><input type="hidden" name="id" value="<%= ticket.id %>"><select name="status"><% ['Open','Waiting User','Resolved','Closed'].forEach(s=>{ %><option value="<%= s %>" <%= ticket.status===s?'selected':'' %>><%= s %></option><% }) %></select><input name="admin_note" placeholder="Balasan/catatan admin" value="<%= ticket.admin_note || '' %>"><button type="submit">Update</button></form></td></tr><% }) %></tbody></table></div></main></div></body></html>