<!DOCTYPE html><html><head><title>Mutasi Saldo - <%= appName || 'DK PANEL' %></title><%- include('partials/panel-head') %></head><body class="mp-body"><div class="mp-layout"><%- include('partials/user-sidebar') %><main class="mp-main"><%- include('partials/panel-top', {title:'Mutasi Saldo', subtitle:'Riwayat keluar masuk saldo.'}) %><section class="mp-card"><div class="mp-card-head"><h2>▤ Mutasi Saldo</h2></div><div class="mp-table-wrap"><table class="mp-table"><thead><tr><th>ID</th><th>Tipe</th><th>Jumlah</th><th>Saldo Awal</th><th>Saldo Akhir</th><th>Deskripsi</th><th>Tanggal</th></tr></thead><tbody><% if((logs||[]).length===0){ %><tr><td colspan="7" class="empty-cell">Belum ada mutasi saldo.</td></tr><% } %><% (logs||[]).forEach(log=>{ %><tr><td><%= log.id %></td><td><%= log.type %></td><td>Rp <%= Number(log.amount||0).toLocaleString('id-ID') %></td><td>Rp <%= Number(log.before_balance||0).toLocaleString('id-ID') %></td><td>Rp <%= Number(log.after_balance||0).toLocaleString('id-ID') %></td><td><%= log.description %></td><td><%= log.created_at ? new Date(log.created_at).toLocaleString('id-ID') : '-' %></td></tr><% }) %></tbody></table></div></section></main></div></body></html>
