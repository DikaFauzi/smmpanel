<!DOCTYPE html><html lang="id"><head><meta charset="UTF-8"><meta name="viewport" content="width=device-width, initial-scale=1"><title><%= service.nama %> - <%= appName %></title><link rel="stylesheet" href="/style.css"></head><body class="mp-public-body"><header class="mp-navbar"><a class="mp-brand" href="/"><span class="mp-brand-logo">M</span><span><%= appName %></span></a><nav class="mp-nav-menu"><a href="/services">Layanan</a><a href="/contoh-pengisian-target">Contoh Target</a><a href="/login" class="mp-nav-login">Masuk</a></nav></header><main class="mp-page-main"><section class="mp-page-hero"><span class="mp-eyebrow"><%= service.kategori %></span><h1><%= service.nama %></h1><p><%= service.description || 'Detail layanan, aturan target, estimasi, dan garansi tersedia di halaman ini.' %></p></section><section class="mp-detail-grid"><article class="mp-page-card"><h2>Informasi Layanan</h2><p>Harga/K: <strong>Rp <%= Number(service.harga||0).toLocaleString('id-ID') %></strong></p><p>Min: <strong><%= Number(service.min_order||0).toLocaleString('id-ID') %></strong> • Max: <strong><%= Number(service.max_order||0).toLocaleString('id-ID') %></strong></p><p>Start: <strong><%= service.start_time || '-' %></strong> • Rata-rata: <strong><%= service.avg_time || '-' %></strong></p><p>Speed: <strong><%= service.speed || '-' %></strong> • Kualitas: <strong><%= service.quality_label || '-' %></strong></p><p>Rating: <strong>⭐ <%= Number(service.rating||5).toFixed(1) %></strong></p><p>Refill: <strong><%= service.refill_type || 'none' %></strong> <% if(service.refill_days){ %> selama <%= service.refill_days %> hari<% } %></p><a class="mp-btn" href="/login">Login untuk Order</a></article><article class="mp-page-card"><h2>Format Target</h2><p><%= service.target_hint || 'Gunakan target sesuai jenis layanan. Jika ragu, lihat halaman contoh pengisian target.' %></p><a class="button-link ghost" href="/contoh-pengisian-target">Lihat Contoh Target</a></article></section><section class="mp-page-card-grid"><% reviews.forEach(review=>{ %><article class="mp-page-card"><h2>⭐ <%= review.rating %>/5</h2><p><%= review.comment || 'Review tanpa komentar.' %></p><span class="muted"><%= review.username %></span></article><% }) %></section></main></body></html>