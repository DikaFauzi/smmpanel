<!DOCTYPE html>
<html>
<head>
    <title>Register - <%= appName || 'DK PANEL' %></title>
    <%- include('partials/panel-head') %>
</head>
<body class="auth-body">
    <main class="auth-shell">
        <section class="auth-hero">
            <div class="auth-brand"><span class="mp-logo">D</span><strong><%= appName || 'DK PANEL' %></strong></div>
            <h1>Bangun akun panel dan mulai pesan layanan sosial media.</h1>
            <p>Daftar, deposit saldo, pilih layanan, lalu pantau status pesanan dari dashboard.</p>
        </section>
        <section class="auth-card">
            <h2>Daftar</h2>
            <p>Buat akun baru untuk mulai menggunakan panel.</p>
            <% if(error){ %><div class="mp-alert"><%= error %></div><% } %>
            <form action="/register" method="POST" class="mp-form">
                <label>Username</label>
                <input type="text" name="username" placeholder="Username" required>
                <label>Email</label>
                <input type="email" name="email" placeholder="email@domain.com" required>
                <label>Password</label>
                <input type="password" name="password" placeholder="Password" required>
                <button type="submit" class="mp-btn mp-btn-full">Daftar</button>
            </form>
            <div class="auth-link">Sudah punya akun? <a href="/login">Masuk</a></div>
        </section>
    </main>
</body>
</html>
