<!DOCTYPE html><html><head><title>Admin Order - <%= appName || 'DK PANEL' %></title><%- include('partials/panel-head') %></head><body class="mp-body"><div class="mp-layout"><%- include('partials/admin-sidebar') %><main class="mp-main"><%- include('partials/panel-top', {title:'Admin Order', subtitle:'Kelola semua order user.'}) %>
<div class="mp-stat-grid"><div class="mp-stat"><span>👥</span><p>Total User</p><strong><%= Number(stats.users.total_users||0).toLocaleString('id-ID') %></strong></div><div class="mp-stat"><span>🛒</span><p>Total Order</p><strong><%= Number(stats.orders.total_orders||0).toLocaleString('id-ID') %></strong></div><div class="mp-stat"><span>▣</span><p>Deposit Pending</p><strong><%= Number(stats.deposits.pending_deposits||0).toLocaleString('id-ID') %></strong></div></div>
<section class="mp-card"><div class="mp-card-head"><h2>🛒 Pesanan</h2></div><div class="mp-filter-grid"><input placeholder="Filter user / email"><select><option>Status</option><option>Pending</option><option>Processing</option><option>Completed</option><option>Canceled</option></select><div class="mp-search"><input placeholder="Cari order..."><button>🔍</button></div></div><div class="mp-table-wrap"><table class="mp-table"><thead><tr><th>ID</th><th>User</th><th>Layanan</th><th>Target</th><th>Jumlah</th><th>Total</th><th>Status</th><th>Aksi</th></tr></thead><tbody><% if((orders||[]).length===0){ %><tr><td colspan="8" class="empty-cell">Belum ada order.</td></tr><% } %><% (orders||[]).forEach(order=>{ %><tr><td>#<%= order.id %></td><td><b><%= order.username %></b><br><small><%= order.email %></small></td><td><%= order.nama %><br><small><%= order.kategori %></small></td><td class="target-cell"><%= order.target %></td><td><%= Number(order.jumlah||0).toLocaleString('id-ID') %></td><td>Rp <%= Number(order.total||0).toLocaleString('id-ID') %></td><td><%- include('partials/status',{status:order.status}) %></td><td><form action="/admin/order/update" method="POST" class="inline-form"><input type="hidden" name="id" value="<%= order.id %>"><select name="status"><% ['Pending','Processing','Completed','Canceled'].forEach(st=>{ %><option value="<%= st %>" <%= order.status===st?'selected':'' %>><%= st %></option><% }) %></select><button class="mp-btn small" type="submit">Simpan</button></form></td></tr><% }) %></tbody></table></div></section>
</main></div></body></html>
